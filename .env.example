# Stack AI API — used by the Next.js BFF at runtime
STACK_AI_BASE_URL=https://api.stackai.com
STACK_AI_SUPABASE_URL=https://sb.stack-ai.com
STACK_AI_SUPABASE_ANON_KEY=<your_supabase_anon_key>
STACK_AI_EMAIL=<your_email>
STACK_AI_PASSWORD=<your_password>

# ── Integration tests (TEST_ prefix) ──────────────────────────────────────────
# All TEST_* vars are REQUIRED — no defaults in code, tests fail fast if missing
TEST_EMAIL=<your_email>
TEST_PASSWORD=<your_password>
TEST_SUPABASE_ANON_KEY=<your_supabase_anon_key>
TEST_SUPABASE_URL=https://sb.stack-ai.com

# API base URLs
# TEST_API_BASE_URL      — actual working URL (ISS-2 fix)
# TEST_API_BASE_URL_DOCS — documented URL in notebook (ISS-2: wrong, used in failure-assertion tests)
TEST_API_BASE_URL=https://api.stackai.com
TEST_API_BASE_URL_DOCS=https://api.stack-ai.com
